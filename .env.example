# Kutirchar EcoFarm — Environment Variables
# Copy this file to .env and fill in your values

# Contact form endpoint (when a backend API is configured)
# VITE_CONTACT_ENDPOINT=https://your-api.com/contact

# Analytics (Plausible or Umami — cookieless, privacy-respecting)
# VITE_ANALYTICS_KEY=your-analytics-key
# VITE_ANALYTICS_DOMAIN=kutircharecofarm.com

# Site URL (used for canonical URLs, sitemap, OG tags)
VITE_SITE_URL=https://kutircharecofarm.com